{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "noEmit": false,
    "rootDir": "./src",
    "types": ["bun", "node", "three"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.fixture.ts",
    "src/examples/**/*",
    "src/benchmark/**/*",
    "src/zig/**/*"
  ]
}
